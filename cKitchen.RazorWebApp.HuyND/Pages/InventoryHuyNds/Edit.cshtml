@page
@model cKitchen.RazorWebApp.HuyND.Pages.InventoryHuyNds.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>InventoryHuyNd</h4>
<hr />
<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">Edit Inventory Item</h4>
            </div>

            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <!-- LEFT -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.InventoryHuyNdid" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.InventoryHuyNdid" class="form-control" readonly/>
                                <span asp-validation-for="InventoryHuyNd.InventoryHuyNdid" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.ItemName" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.ItemName" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.ItemName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.Quantity" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.Quantity" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.Quantity" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.Unit" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.Unit" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.Unit" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.ExpiryDate" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.ExpiryDate" type="date" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.ExpiryDate" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.BatchNumber" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.BatchNumber" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.BatchNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- RIGHT -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.Cost" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.Cost" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.Cost" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.Status" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.Status" class="form-control" />
                                <span asp-validation-for="InventoryHuyNd.Status" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.CentralKitchenKhaiVpmid"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="InventoryHuyNd.CentralKitchenKhaiVpmid"
                                       class="form-control"
                                       readonly />

                                <span asp-validation-for="InventoryHuyNd.CentralKitchenKhaiVpmid"
                                      class="text-danger"></span>
                            </div>


                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.InventoryLocationHuyNdid" class="form-label fw-semibold"></label>
                                <select asp-for="InventoryHuyNd.InventoryLocationHuyNdid"
                                        class="form-select"
                                        asp-items="ViewBag.InventoryLocationHuyNdid">
                                </select>
                                <span asp-validation-for="InventoryHuyNd.InventoryLocationHuyNdid" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Is Active</label>
                                <div class="form-check form-switch">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           name="InventoryHuyNd.IsActive"
                                           value="true"
                                    @(Model.InventoryHuyNd.IsActive == true ? "checked" : "") />
                                    <label class="form-check-label">Active</label>
                                </div>
                            </div>


                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.CreatedDate" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.CreatedDate"
                                       class="form-control bg-light"
                                       readonly />
                            </div>

                            <div class="mb-3">
                                <label asp-for="InventoryHuyNd.UpdatedDate" class="form-label fw-semibold"></label>
                                <input asp-for="InventoryHuyNd.UpdatedDate"
                                       class="form-control bg-light"
                                       readonly />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            Back
                        </a>
                        <button type="submit" class="btn btn-warning px-4">
                            Save Changes
                        </button>

                        <input type="button" id="btnHubUpdate" value="Update by Signal" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<script src="~/js/signalr/dist/browser/signalr.js"> </script>

<script>
    "use strict";

    var connection = new signalR.HubConnectionBuilder().withUrl("/ckitchenHub").build();

    connection.start().then(function () {
        console.log("Connected to the SignalR Hub");
    }).catch(function (err) {
        return console.error(err.toString());
    });

    document.getElementById("btnHubUpdate").addEventListener("click", function (event) {

        var dataObj = JSON.stringify({
			InventoryHuyNdid: document.getElementById("InventoryHuyNd_InventoryHuyNdid").value,
            ItemName: document.getElementById("InventoryHuyNd_ItemName").value,
            Quantity: document.getElementById("InventoryHuyNd_Quantity").value,
            Unit: document.getElementById("InventoryHuyNd_Unit").value,
            ExpiryDate: document.getElementById("InventoryHuyNd_ExpiryDate").value,
            BatchNumber: document.getElementById("InventoryHuyNd_BatchNumber").value,

            Cost: document.getElementById("InventoryHuyNd_Cost").value,
            Status: document.getElementById("InventoryHuyNd_Status").value,
            InventoryLocationHuyNdid: document.getElementById("InventoryHuyNd_InventoryLocationHuyNdid").value,

            CentralKitchenKhaiVpmid: document.getElementById("InventoryHuyNd_CentralKitchenKhaiVpmid").value,
            CreatedDate: document.getElementById("InventoryHuyNd_CreatedDate").value,
            UpdatedDate: document.getElementById("InventoryHuyNd_UpdatedDate").value,
            IsActive: document.querySelector('input[name="InventoryHuyNd.IsActive"]').checked
        });

        //console.log(dataObj);

    connection.invoke("HubUpdate_InventoryHuyND", dataObj).catch(function (err) {
            return console.error(err.toString());
        });
        event.preventDefault();

    });

</script>